<?xml version="1.0" encoding="UTF-8"?>

<!--
   Auteur : Hugo VITORINO PEREIRA
   Date : 02/03/2025
   Description : Fenêtre permettant de rechercher une réservation d'un client.
-->

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="pageRechercheReservation" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="720.0" prefWidth="1280.0" stylesheets="@../../../styles/style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.clients.reservations.ReservationRechercheController">
    <top>
        <fx:include source="../../BarreMenu.fxml" />
    </top>
    <center>
        <VBox fx:id="vb" alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
            <children>
                <HBox fx:id="hbBoutonDeRecherche" alignment="BOTTOM_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="132.0" prefWidth="1280.0" spacing="5.0" VBox.vgrow="ALWAYS">
                    <children>
                        <ComboBox fx:id="rechercherParComboBox" prefHeight="32.0" prefWidth="171.0" promptText="Rechercher par" styleClass="rechercher-par" HBox.hgrow="ALWAYS">
                            <HBox.margin>
                                <Insets />
                            </HBox.margin>
                        </ComboBox>
                        <TextField fx:id="zoneRechercherReservationTextField" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="35.0" prefWidth="381.0" promptText="Rechercher une réservation" styleClass="barre-recherche" HBox.hgrow="ALWAYS">
                     <HBox.margin>
                        <Insets left="50.0" />
                     </HBox.margin></TextField>
                    </children>
                </HBox>
            <TableView fx:id="resaTableView" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" onMouseClicked="#tableViewClickHandler" prefHeight="358.0" prefWidth="713.0">
              <columns>
                <TableColumn fx:id="dateResaColumn" prefWidth="247.9999589920044" text="Date" />
                <TableColumn fx:id="numResaColumn" prefWidth="434.0000305175781" text="Numéro de réservation" />
              </columns>
               <VBox.margin>
                  <Insets top="30.0" />
               </VBox.margin>
            </TableView>
            </children>
         <BorderPane.margin>
            <Insets />
         </BorderPane.margin>
        </VBox>
    </center>
   <bottom>
      <HBox fx:id="zoneBouton" alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="retourFenetrePrecedenteButton" mnemonicParsing="false" onAction="#retourHandler" prefHeight="30.0" styleClass="bouton-retour" text="Retour" HBox.hgrow="ALWAYS">
               <HBox.margin>
                  <Insets left="50.0" />
               </HBox.margin>
            </Button>
         </children>
      </HBox>
   </bottom>
</BorderPane>
