<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!-- Structure de la page permettant de rembourser un client -->

<BorderPane prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ventes.VentesSansOrdonnanceController">


   <!-- Introduction de la barre de menu -->
   <top>
      <fx:include source="../BarreMenu.fxml" />
   </top>


   <center>
      <HBox maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="403.0" prefWidth="1211.0" BorderPane.alignment="CENTER">
         <VBox fx:id="vb" alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="403.0" prefWidth="782.0" spacing="30.0" HBox.hgrow="ALWAYS">
            <HBox fx:id="hbRecherche" alignment="BOTTOM_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="32.0" prefWidth="1280.0" spacing="30.0" VBox.vgrow="ALWAYS">

               <!-- Permet de rechercher un client par un certain critère -->
               <ComboBox fx:id="rechercherParButton" prefHeight="22.0" prefWidth="136.0" promptText="Rechercher par" HBox.hgrow="ALWAYS" />

               <!-- Permet de rechercher un client -->
               <TextField fx:id="zoneRechercheMedicament" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="25.0" prefWidth="510.0" HBox.hgrow="ALWAYS" />
            </HBox>
            <TableView fx:id="zoneAffichageMedicament" maxHeight="-Infinity" maxWidth="-Infinity" onMouseClicked="#listViewClickHandler" prefHeight="423.0" prefWidth="736.0">
               <columns>
                  <TableColumn fx:id="codeCisColumn" prefWidth="151.0" text="Code CIS" />
                  <TableColumn fx:id="denominationColumn" prefWidth="250.0" text="Dénomination" />
                  <TableColumn fx:id="prixColumn" minWidth="2.0" prefWidth="102.0" text="Prix" />
                  <TableColumn fx:id="quantiteColumn" minWidth="2.0" prefWidth="85.0" text="Quantité" />
                  <TableColumn fx:id="dosageColumn" minWidth="2.0" prefWidth="147.0" text="Dosage" />
               </columns>
            </TableView>
         </VBox>
         <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" spacing="50.0">
            <VBox alignment="TOP_RIGHT" prefHeight="483.0" prefWidth="393.0" spacing="30.0" VBox.vgrow="ALWAYS">
               <TableView fx:id="zonePanierMedicament" maxHeight="-Infinity" maxWidth="-Infinity" onMouseClicked="#listViewClickHandler" prefHeight="408.0" prefWidth="393.0">
                  <columns>
                     <TableColumn fx:id="denominationPanierColumn" prefWidth="174.0" text="Dénomination" />
                     <TableColumn fx:id="prixPanierColumn" minWidth="2.0" prefWidth="64.0" text="Prix" />
                     <TableColumn fx:id="quantitePanierColumn" minWidth="2.0" prefWidth="66.0" text="Quantité" />
                     <TableColumn fx:id="actionsPanierColumn" minWidth="2.0" prefWidth="88.0" />
                  </columns>
                  <VBox.margin>
                     <Insets top="55.0" />
                  </VBox.margin>
               </TableView>
               <Label fx:id="totalLabel" text="Total : " VBox.vgrow="ALWAYS" />
               <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" spacing="30.0" VBox.vgrow="ALWAYS">

                  <!-- Bouton permettant de revenir à la page des Remboursements -->
                  <Button fx:id="annulerButton" mnemonicParsing="false" onMouseClicked="#annulerHandler" styleClass="bouton-rouge" text="ANNULER" />

                  <!-- Bouton permettant de rembourser le client et d'ajouter le remboursement à la base de données des clients -->
                  <Button fx:id="vendreButton" mnemonicParsing="false" onMouseClicked="#vendreHandler" styleClass="bouton-vert" text="VENDRE" />
               </HBox>
            </VBox>
         </VBox>
      </HBox>
   </center>

   <stylesheets>
      <URL value="@../../styles/style-rechercher.css" />
      <URL value="@../../styles/style-boutons.css" />
   </stylesheets>
   <bottom>
      <VBox alignment="CENTER" prefHeight="93.0" prefWidth="1280.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="(Double-cliquez pour ajouter un médicament dans le panier)" />
            <Label prefHeight="25.0" prefWidth="319.0" text="(Faites un clic droit pour ajouter une quantité personnalisée)" />
         </children>
      </VBox>
   </bottom>

</BorderPane>
