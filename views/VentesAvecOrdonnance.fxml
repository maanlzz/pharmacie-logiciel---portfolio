<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!-- Structure de la page permettant de rembourser un client -->

<BorderPane prefHeight="720.0" prefWidth="1280.0" styleClass="label" stylesheets="@../../styles/barre-de-menu.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ventes.VentesAvecOrdonnanceController">


   <!-- Introduction de la barre de menu -->
   <top>
      <fx:include source="../BarreMenu.fxml" />
   </top>
   <center>
      <ScrollPane minHeight="-Infinity" minWidth="-Infinity" prefHeight="616.0" prefWidth="1280.0" stylesheets="@../../styles/style.css" BorderPane.alignment="TOP_LEFT">
         <BorderPane.margin>
            <Insets />
         </BorderPane.margin>
         <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="563.0" prefWidth="1274.0" spacing="30.0">
            <padding>
               <Insets bottom="60.0" top="60.0" />
            </padding>
            <HBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="403.0" prefWidth="1195.0" VBox.vgrow="ALWAYS">
               <VBox fx:id="vb1" alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="403.0" prefWidth="829.0" spacing="30.0" HBox.hgrow="ALWAYS">
                  <HBox fx:id="hbRecherche1" alignment="BOTTOM_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="32.0" prefWidth="1280.0" spacing="30.0" VBox.vgrow="ALWAYS">
                     <children>
                        <Button fx:id="selectionnerClientBouton" mnemonicParsing="false" onAction="#selectionnerClientHandler" styleClass="bouton-jaune" stylesheets="@../../styles/style.css" text="SELECTIONNER UN CLIENT" />
                        <Button fx:id="selectionnerOrdonnanceBouton" alignment="CENTER" contentDisplay="CENTER" disable="true" mnemonicParsing="false" onAction="#selectionnerOrdonnanceHandler" styleClass="bouton-vert" stylesheets="@../../styles/style.css" text="SELECTIONNER UNE ORDONNANCE" />
                     </children>
                  </HBox>
                  <TableView fx:id="zoneAffichageClient" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="70.0" prefWidth="736.0" styleClass="label" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="nomClient" minWidth="2.0" prefWidth="226.0" text="Nom" />
                        <TableColumn fx:id="prenomClient" minWidth="2.0" prefWidth="216.0" text="Prenom" />
                        <TableColumn fx:id="dateNaissanceClient" minWidth="2.0" prefWidth="293.0" text="Date de naissance" />
                     </columns>
                  </TableView>
                  <TableView fx:id="ZoneAffichageOrdonnance" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="189.0" prefWidth="736.0">
                     <columns>
                        <TableColumn fx:id="dateOrdonnance" prefWidth="75.0" text="Date" />
                        <TableColumn fx:id="medecinOrdonnance" prefWidth="232.00003051757812" text="Médecin" />
                        <TableColumn fx:id="nomOrdonnance" prefWidth="254.6666259765625" text="Ordonnance" />
                        <TableColumn fx:id="actionsOrdonnanceColumn" prefWidth="172.0" text="Actions" />
                     </columns>
                  </TableView>
               </VBox>
               <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="403.0" prefWidth="395.0" spacing="50.0" HBox.hgrow="ALWAYS">
                  <children>
                     <VBox alignment="TOP_RIGHT" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="403.0" prefWidth="300.0" spacing="30.0" VBox.vgrow="ALWAYS">
                        <VBox alignment="BOTTOM_RIGHT" prefHeight="200.0" prefWidth="100.0" spacing="30.0" VBox.vgrow="ALWAYS">
                           <TableView fx:id="zonePanierMedicament" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" onMouseClicked="#listViewClickHandler" prefHeight="341.0" prefWidth="428.0" VBox.vgrow="ALWAYS">
                              <columns>
                                 <TableColumn fx:id="denominationPanierColumn" prefWidth="129.0" text="Dénomination" />
                                 <TableColumn fx:id="prixPanierColumn" minWidth="2.0" prefWidth="51.0" text="Prix" />
                                 <TableColumn fx:id="quantitePanierColumn" minWidth="2.0" prefWidth="62.0" text="Quantité" />
                                 <TableColumn fx:id="actionsPanierColumn" minWidth="2.0" prefWidth="89.99998474121094" />
                                 <TableColumn fx:id="indispoColumn" minWidth="2.0" prefWidth="94.6666259765625" text="Indisponible" />
                              </columns>
                              <VBox.margin>
                                 <Insets top="55.0" />
                              </VBox.margin>
                           </TableView>
                        </VBox>
                     </VBox>
                  </children>
               </VBox>
            </HBox>
            <HBox prefHeight="81.0" prefWidth="1274.0">
               <children>
                  <Button fx:id="ajouterClientBouton" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#ajouterClientHandler" onMouseClicked="#ajouterOrdonnanceHandler" prefHeight="25.0" prefWidth="209.0" styleClass="bouton-jaune" stylesheets="@../../styles/style.css" text="AJOUTER UN CLIENT">
                     <HBox.margin>
                        <Insets left="300.0" />
                     </HBox.margin>
                  </Button>
                  <Button fx:id="ajouterOrdonnanceBouton1" disable="true" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#ajouterOrdonnanceHandler" onMouseClicked="#ajouterClientHandler" prefHeight="25.0" prefWidth="187.0" styleClass="bouton-vert" stylesheets="@../../styles/style.css" text="AJOUTER UNE ORDONNANCE">
                     <HBox.margin>
                        <Insets left="30.0" />
                     </HBox.margin>
                  </Button>
                  <VBox alignment="TOP_RIGHT" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="100.0" prefWidth="475.0" spacing="30.0">
                     <Label fx:id="totalLabel" text="Total : " VBox.vgrow="ALWAYS">
                        <VBox.margin>
                           <Insets right="20.0" />
                        </VBox.margin></Label>
                     <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" spacing="30.0" VBox.vgrow="ALWAYS">
                        <Button fx:id="reserverButton" disable="true" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onMouseClicked="#reserverHandler" prefHeight="25.0" prefWidth="83.0" styleClass="bouton-jaune" stylesheets="@../../styles/style.css" text="RESERVER" />

                        <!-- Bouton permettant de revenir à la page des Remboursements -->
                        <Button fx:id="annulerButton" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onMouseClicked="#annulerHandler" prefHeight="25.0" prefWidth="83.0" styleClass="bouton-rouge" stylesheets="@../../styles/style.css" text="ANNULER" />

                        <!-- Bouton permettant de rembourser le client et d'ajouter le remboursement à la base de données des clients -->
                        <Button fx:id="vendreButton" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onMouseClicked="#vendreHandler" prefHeight="25.0" prefWidth="76.0" styleClass="bouton-vert" stylesheets="@../../styles/style.css" text="VENDRE">
                           <HBox.margin>
                              <Insets right="20.0" />
                           </HBox.margin></Button>
                     </HBox>
                     <padding>
                        <Insets left="300.0" />
                     </padding>
                  </VBox>
               </children>
            </HBox>
            <HBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="403.0" prefWidth="1089.0" VBox.vgrow="ALWAYS">
               <VBox fx:id="vb" alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="403.0" prefWidth="782.0" spacing="30.0" HBox.hgrow="ALWAYS">
                  <HBox fx:id="hbRecherche" alignment="BOTTOM_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="32.0" prefWidth="1280.0" spacing="30.0" VBox.vgrow="ALWAYS">

                     <!-- Permet de rechercher un client par un certain critère -->
                     <ComboBox fx:id="rechercherParButton" prefHeight="22.0" prefWidth="136.0" promptText="Rechercher par" HBox.hgrow="ALWAYS" />

                     <!-- Permet de rechercher un client -->
                     <TextField fx:id="zoneRechercheMedicament" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="25.0" prefWidth="510.0" HBox.hgrow="ALWAYS" />
                  </HBox>
                  <TableView fx:id="zoneAffichageMedicament" maxHeight="-Infinity" maxWidth="-Infinity" onMouseClicked="#listViewClickHandler" prefHeight="423.0" prefWidth="736.0">
                     <columns>
                        <TableColumn fx:id="codeCisColumn" prefWidth="151.0" text="Code CIS" />
                        <TableColumn fx:id="denominationColumn" prefWidth="250.0" text="Dénomination" />
                        <TableColumn fx:id="prixColumn" minWidth="2.0" prefWidth="102.0" text="Prix" />
                        <TableColumn fx:id="quantiteColumn" minWidth="2.0" prefWidth="85.0" text="Quantité" />
                        <TableColumn fx:id="dosageColumn" minWidth="2.0" prefWidth="147.0" text="Dosage" />
                     </columns>
                  </TableView>
               </VBox>
               <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="403.0" prefWidth="329.0" spacing="50.0" HBox.hgrow="ALWAYS" />
            </HBox>
         </VBox>
      </ScrollPane>
   </center>

</BorderPane>
